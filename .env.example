# ============================================
#  mx-trader-bridge 环境变量模板
#  复制为 .env 后填入真实值
# ============================================

# === 妙想模拟盘 ===
MX_APIKEY=***
MX_API_URL=https://mkapi2.dfcfs.com/finskillshub

# === AI 决策（自配，留空则跳过 AI 风控用默认值）===
LLM_PROVIDER=ark
LLM_API_KEY=
LLM_MODEL=ark-code-latest
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# === 仓位配置 ===
POSITION_COUNT=2
POSITION_PCT=0.5

# === 告警通道（任选其一，全留空则只打印控制台）===
# 企业微信群机器人（推荐 ✅，无关键词限制，20条/分钟）
WECOM_BOT_WEBHOOK=

# 飞书自定义机器人
FEISHU_WEBHOOK=

# Server酱 SCT 密钥（免费版 5条/天）
SERVERCHAN_KEY=
